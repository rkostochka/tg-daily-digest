# Telegram MTProto credentials (https://my.telegram.org)
TG_API_ID=
TG_API_HASH=
# StringSession после первой авторизации (получается через `python auth.py`)
TG_SESSION=

# OpenRouter (https://openrouter.ai/keys) — бесплатный ключ
OPENROUTER_API_KEY=

# Куда слать дайджест
TARGET_CHAT_ID=-1003957373164

# Какие папки читать (через запятую, имена как в Telegram)
FOLDERS=Fin,Interests,Data,News

# Сколько часов назад смотреть
LOOKBACK_HOURS=24

# Модель OpenRouter (бесплатные варианты см. README)
LLM_MODEL=google/gemini-2.0-flash-exp:free
