# Бот (токен от BotFather — бот должен быть добавлен в целевую группу)
BOT_TOKEN=

# Куда слать дайджест (ID группы)
TARGET_CHAT_ID=-1003957373164

# Список @username каналов через запятую (без @)
# Вставьте username каналов из ваших папок Fin, Interests, Data, News
CHANNELS=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Опционально — менять через GitHub Variables, а не Secrets
LOOKBACK_HOURS=24
LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# RSS-ленты блогов и изданий (опционально).
# Если не задано — используется встроенный список по умолчанию:
#   Simon Willison, One Useful Thing, Lilian Weng, Import AI, HuggingFace Blog, Pragmatic Engineer.
# Формат: "Имя1|url1,Имя2|url2,..."
# Пример:
# RSS_FEEDS=Simon Willison|https://simonwillison.net/atom/everything/,One Useful Thing|https://www.oneusefulthing.org/feed
RSS_FEEDS=

# Окно для RSS-лент (часов). 48 ч по умолчанию — статьи выходят реже, чем TG-посты.
RSS_LOOKBACK_HOURS=48
